#!/bin/bash
set -e
set -u

name="dev_env"
dir="${HOME}/Programming/${name}"

function print {
    echo "$(tput setaf 6)${*}$(tput sgr0)"
}

print "-> Requesting sudo access"
sudo echo

print "-> Configuring brew"
NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
eval "$(/opt/homebrew/bin/brew shellenv)"
brew analytics off

print "-> Installing git and pulling repo"
brew install git
git clone "git@github.com:larzconwell/${name}.git" "${dir}"

print "-> Configuring dotfiles"
"${dir}/scripts/link_files" "${dir}/dotfiles" "${HOME}" "."

print "-> Installing brew formulas"
brew bundle install --file "${dir}/Brewfile"

print "-> Installing mise tools"
eval "$(mise activate bash)"
mise install

print "-> Configuring Docker"
mkdir -p "${HOME}/.docker"
ln -sfn "$(brew --prefix)/lib/docker/cli-plugins" "${HOME}/.docker/cli-plugins"
colima start --vm-type vz --kubernetes

print "-> Configuring root password"
sudo passwd

print "-> Configuring shell"
which zsh | sudo tee -a /etc/shells 1>/dev/null 2>&1
chsh -s "$(which zsh)"
sudo chsh -s "$(which zsh)"
